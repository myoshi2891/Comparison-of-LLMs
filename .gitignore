# ========================================
# AI Model Pricing .gitignore
# ========================================

# OS
.DS_Store
Thumbs.db

# IDE / Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.history/
*.iml
*.swp
*.swo

# Python (scraper/)
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.venv/
venv/
ENV/
.Python
.mypy_cache/
*.egg-info/
.pytest_cache/

# Node.js (web/)
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
.eslintcache
.stylelintcache

# Security / Environment
.env
.env.local
.env.*.local
!.env.example
credentials.json
config.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Data / Generated Assets (Root)
# Set these if you want to keep generated assets out of Git
/index.html
/*.png
/*.ico

# Backup/Temp
*.tmp
*.bak

# temp files
links.md

# Claude Code local settings (personal, not shared)
CLAUDE.local.md

# git worktree のチェックアウト先を追跡対象から除外（必須）
worktrees/
sample-docs

# 旧 Vite/HTML 資産（Phase 14 カットオーバー済）。Phase A–F でガイドページを Next.js 化中。
# 物理削除は避け、ローカル参照用に保持。以降の git add legacy/... は暗黙ブロックされる。
# 注: 既に HEAD に commit 済のため、git rm --cached は実施していない（HEAD 履歴は保全）。
legacy/

# Claude Code local settings
.claude/settings.local.json

pricing_old.json
/archive/
md-for-update